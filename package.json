{
  "name": "tkm-ai-engineer",
  "version": "1.0.0",
  "description": "Professional Autonomous PLC Engineer",
  "main": "main.js",
  "author": "Gajanan Patagar",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "dist": "next build && electron-builder --win --portable"
  },
  "build": {
    "appId": "com.tkm.ai.engineer",
    "productName": "TKM AI Engineer",
    "directories": { "output": "dist" },
    "files": [ "out/**/*", "main.js", "package.json", "public/**/*" ],
    "win": {
      "target": "portable",
      "requestedExecutionLevel": "asInvoker"
    }
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
