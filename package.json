{
  "name": "tkm-ai-engineer",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "build": "next build",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.tkm.ai",
    "productName": "TKM AI Engineer",
    "directories": { "output": "dist" },
    "files": [ "out/**/*", "main.js", "package.json" ],
    "win": { 
      "target": "portable" 
    }
  },
  "dependencies": {
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "@types/react": "latest",
    "@types/node": "latest",
    "@types/react-dom": "latest"
  }
}
